{
  "name": "oshi-idol",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@trpc/server": "^11.16.0",
      "@trpc/client": "^11.16.0",
      "better-auth": "1.6.9",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.91.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:generate": "turbo -F @oshi-idol/db db:generate",
    "db:migrate:local": "cd apps/web && npx wrangler d1 migrations apply oshi-idol-db-local --local --config .alchemy/local/wrangler.jsonc",
    "db:studio": "turbo -F @oshi-idol/db db:studio",
    "db:seed:local": "turbo -F @oshi-idol/db db:seed:local",
    "db:fetch-seed-data": "turbo -F @oshi-idol/scraper fetch-seed-fixtures",
    "deploy": "turbo -F @oshi-idol/infra deploy",
    "destroy": "turbo -F @oshi-idol/infra destroy",
    "check": "oxlint --ignore-pattern '.claude' && oxfmt --write"
  },
  "dependencies": {
    "@oshi-idol/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@oshi-idol/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.11"
}
